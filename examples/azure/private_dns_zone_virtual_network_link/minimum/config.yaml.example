# Private DNS Zone Virtual Network Link — minimum configuration example
# Links a VNet to a Private DNS Zone for private name resolution.
# Drive via: TF_VAR_config_file=configurations/my.yaml terraform -chdir=.build apply

default_location: westeurope

azure_resource_groups:
  dns:
    subscription_id: "00000000-0000-0000-0000-000000000000"
    resource_group_name: rg-dns-example
    location: westeurope

azure_virtual_networks:
  main:
    subscription_id: "00000000-0000-0000-0000-000000000000"
    resource_group_name: ref:azure_resource_groups.dns.resource_group_name
    virtual_network_name: vnet-example
    location: ref:azure_resource_groups.dns.location
    address_space:
      - 10.0.0.0/16

azure_private_dns_zones:
  monitor:
    subscription_id: "00000000-0000-0000-0000-000000000000"
    resource_group_name: ref:azure_resource_groups.dns.resource_group_name
    zone_name: privatelink.monitor.azure.com

azure_private_dns_zone_virtual_network_links:
  minimum:
    subscription_id: "00000000-0000-0000-0000-000000000000"
    resource_group_name: ref:azure_resource_groups.dns.resource_group_name
    private_dns_zone_name: ref:azure_private_dns_zones.monitor.name
    virtual_network_link_name: link-vnet-to-monitor
    virtual_network_id: ref:azure_virtual_networks.main.id
