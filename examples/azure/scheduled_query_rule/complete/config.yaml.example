default_location: westeurope

terraform_backend:
  type: local
  path: scheduled_query_rule_complete.tfstate

azure_resource_groups:
  example:
    resource_group_name: rg-observability
    location: westeurope
    tags:
      environment: dev
      scenario: sqr-complete

azure_log_analytics_workspaces:
  example:
    resource_group_name: ref:azure_resource_groups.example.resource_group_name
    workspace_name: law-sqr
    location: ref:azure_resource_groups.example.location
    tags: ref:azure_resource_groups.example.tags

azure_action_groups:
  example:
    resource_group_name: ref:azure_resource_groups.example.resource_group_name
    action_group_name: ag-ops
    short_name: ops
    email_receivers:
      - name: ops-email
        email_address: ops@example.com

azure_scheduled_query_rules:
  complete:
    subscription_id: "00000000-0000-0000-0000-000000000000"
    resource_group_name: ref:azure_resource_groups.example.resource_group_name
    rule_name: sqr-failed-requests-complete
    location: ref:azure_resource_groups.example.location
    description: "Alert on failed HTTP requests in Application Insights"
    display_name: "Failed Requests Alert"
    enabled: true
    severity: 2
    scopes:
      - ref:azure_log_analytics_workspaces.example.id
    evaluation_frequency: PT15M
    window_size: PT15M
    auto_mitigate: true
    mute_actions_duration: PT30M
    criteria:
      all_of:
        - query: "requests | where success == false"
          time_aggregation: Count
          operator: GreaterThan
          threshold: 5
          failing_periods:
            number_of_evaluation_periods: 1
            min_failing_periods_to_alert: 1
    actions:
      action_groups:
        - ref:azure_action_groups.example.id
    tags: ref:azure_resource_groups.example.tags
