default_location: westeurope

terraform_backend:
  type: local
  path: data_collection_endpoint_minimum.tfstate

azure_resource_groups:
  example:
    resource_group_name: rg-dce
    location: westeurope

azure_data_collection_endpoints:
  minimum:
    subscription_id: "00000000-0000-0000-0000-000000000000"
    resource_group_name: ref:azure_resource_groups.example.resource_group_name
    data_collection_endpoint_name: dce-example
    location: ref:azure_resource_groups.example.location
    public_network_access: Enabled
